[app]
title = Ziyad Ultra AI
package.name = ziyadpro
package.domain = org.ziyad
source.dir = .
source.include_exts = py,png,jpg,kv,atlas
version = 0.1
requirements = python3,kivy
orientation = portrait
fullscreen = 0
